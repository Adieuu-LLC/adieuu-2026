# Desktop App Environment Configuration
# Copy this file to .env and update values as needed

# API base URL - where the backend API is running
VITE_API_URL=http://localhost:4000

# Chat WebSocket URL - where the chat server is running
VITE_CHAT_WS_URL=ws://localhost:9001/ws/chat

# --- Main process: cookie + CORS bridge (apps/desktop/.env is loaded at startup) ---
#
# Packaged builds always enable the bridge for the default Adieuu hosts (api, ws,
# downloads, media, status). Development uses Vite (http://localhost:5173); set
# the flag below to enable the same bridge against local or staging APIs.
#
# ADIEUU_ENABLE_COOKIE_BRIDGE=1
#
# Comma-separated hostnames or host:port tokens merged with the built-in list:
# ADIEUU_COOKIE_BRIDGE_EXTRA_HOSTS=localhost:4000,localhost:9001
#
# Non-empty value replaces the built-in list entirely (staging-only overrides):
# ADIEUU_COOKIE_BRIDGE_HOSTS=api.staging.example.com,localhost:4000
