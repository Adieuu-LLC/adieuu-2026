{
  "name": "@adieuu/desktop",
  "version": "0.1.11",
  "description": "Adieuu Desktop - Secure encrypted messaging application",
  "author": {
    "name": "Adieuu Team",
    "email": "team@adieuu.im"
  },
  "homepage": "https://adieuu.im",
  "private": true,
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist out"
  },
  "dependencies": {
    "@adieuu/shared": "workspace:*",
    "@adieuu/ui": "workspace:*",
    "i18next": "^24.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.4.1",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@adieuu/tsconfig": "workspace:*",
    "@swc/core": "^1.10.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^37.7.5",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "sass-embedded": "^1.83.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "com.adieuu.desktop",
    "productName": "Adieuu",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Utility",
      "maintainer": "Adieuu Team <team@adieuu.im>"
    }
  }
}
