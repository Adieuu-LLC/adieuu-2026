# Adieuu API Environment Variables
# Copy this file to .env and fill in your values
#
# Usage:
#   cp env.example .env
#   # Edit .env with your values

# =============================================================================
# Server
# =============================================================================
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
# Max JSON/request body size (bytes). Default matches @adieuu/shared and Terraform api_max_request_body_bytes.
# MAX_REQUEST_BODY_BYTES=256000
# Stricter cap for clients without a resolvable adieuu_session (see router resolve-body-limit). Capped to MAX.
# ANONYMOUS_MAX_REQUEST_BODY_BYTES=16384

# =============================================================================
# CORS
# Multiple origins can be comma-separated for web + desktop development
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=true

# =============================================================================
# MongoDB
# =============================================================================
MONGODB_URI=mongodb://localhost:27018
MONGODB_DB_NAME=adieuu
# MONGODB_MIN_POOL_SIZE=5
# MONGODB_MAX_POOL_SIZE=20

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379
# REDIS_KEY_PREFIX=adieuu:

# =============================================================================
# Security Secrets
# IMPORTANT: Generate unique secrets for each environment!
# Use: openssl rand -base64 32
# =============================================================================
CSRF_SECRET=dev-csrf-secret-change-in-prod
SESSION_SECRET=dev-session-secret-change-in-prod
OTP_SECRET=dev-otp-secret-change-in-prod

# =============================================================================
# Email (AWS SES)
# For local dev, set EMAIL_PROVIDER=console to log emails instead of sending
# =============================================================================
EMAIL_PROVIDER=console
EMAIL_FROM_ADDRESS=noreply@adieuu.local
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# =============================================================================
# SMS (TextMagic)
# For local dev, set SMS_PROVIDER=console to log SMS instead of sending
# =============================================================================
SMS_PROVIDER=console
SMS_FROM_NAME=Adieuu
# TEXTMAGIC_USERNAME=
# TEXTMAGIC_API_KEY=

# =============================================================================
# Client URLs
# =============================================================================
WEB_APP_URL=http://localhost:3000

# =============================================================================
# Feature Flags
# =============================================================================
# Set to true to require DB connections (fail startup if DBs unavailable)
REQUIRE_DATABASE=false

# Set to true to create MongoDB database and collections on startup
# Useful for dev/staging to ensure collections exist before any data is written
# INITIALIZE_COLLECTIONS=true

# =============================================================================
# Rate Limiting
# Set RATE_LIMIT_ENABLED=false to disable all rate limiting for development
# =============================================================================
RATE_LIMIT_ENABLED=true

# Auth OTP request limits (per identifier: email/phone)
# RATE_LIMIT_AUTH_REQUEST_IDENTIFIER=3
# RATE_LIMIT_AUTH_REQUEST_IDENTIFIER_WINDOW=900

# Auth OTP request limits (per IP)
# RATE_LIMIT_AUTH_REQUEST_IP=10
# RATE_LIMIT_AUTH_REQUEST_IP_WINDOW=900

# Auth verify limits (per identifier)
# RATE_LIMIT_AUTH_VERIFY_IDENTIFIER=5
# RATE_LIMIT_AUTH_VERIFY_IDENTIFIER_WINDOW=900

# Auth verify limits (per IP)
# RATE_LIMIT_AUTH_VERIFY_IP=20
# RATE_LIMIT_AUTH_VERIFY_IP_WINDOW=900

# Global API rate limits
# RATE_LIMIT_GLOBAL_USER=100
# RATE_LIMIT_GLOBAL_USER_WINDOW=60
# RATE_LIMIT_GLOBAL_IP=1000
# RATE_LIMIT_GLOBAL_IP_WINDOW=60

# =============================================================================
# Platform settings (MongoDB collection `platform_settings`)
# =============================================================================
# No dedicated env vars. Documented keys include platform-auth-allowlist-enforced,
# platform-auth-allowlist-email, platform-auth-allowlist-phone, platform-admin-account-list.
# Seed `platform-admin-account-list` with user ObjectIds in Mongo before using
# GET/PUT/PATCH /api/admin/platform-settings (requires session + admin list).

# =============================================================================
# LiveKit (calls / audio-video)
# Self-hosted LiveKit SFU for group calls. Set LIVEKIT_ENABLED=true to activate.
# When enabled, startup validates that API_KEY, API_SECRET, and URL are all set.
# =============================================================================
LIVEKIT_ENABLED=false
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_URL=ws://localhost:7880
# LIVEKIT_TOKEN_TTL_SEC=600
