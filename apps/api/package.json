{
  "name": "@adieuu/api",
  "version": "0.3.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "test": "bash scripts/run-tests.sh",
    "test:coverage": "bash scripts/run-tests-with-coverage.sh",
    "test:ci": "bash scripts/run-tests-with-coverage.sh --reporter=junit --reporter-outfile=junit.xml",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "seed:jurisdiction-requirements": "bun run scripts/seed-jurisdiction-requirements.ts",
    "seed:sanctioned-countries": "bun run scripts/seed-sanctioned-countries.ts"
  },
  "dependencies": {
    "@adieuu/crypto": "workspace:*",
    "@adieuu/shared": "workspace:*",
    "@aws-sdk/client-s3": "3.1018.0",
    "@aws-sdk/client-secrets-manager": "3.1018.0",
    "@aws-sdk/cloudfront-signer": "3.1074.0",
    "@aws-sdk/s3-presigned-post": "3.1018.0",
    "@aws-sdk/s3-request-presigner": "3.1018.0",
    "@friendlycaptcha/server-sdk": "0.3.0",
    "@simplewebauthn/server": "13.2.2",
    "ioredis": "5.9.3",
    "livekit-server-sdk": "2.15.4",
    "mongodb": "6.21.0",
    "otpauth": "9.5.0",
    "stripe": "22.1.0",
    "winston": "3.19.0",
    "winston-transport": "4.9.0"
  },
  "devDependencies": {
    "@adieuu/tsconfig": "workspace:*",
    "@types/bun": "1.3.9",
    "typescript": "5.9.3"
  }
}
