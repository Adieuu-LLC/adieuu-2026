{
  "name": "@adieuu/api",
  "version": "0.1.7",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:ci": "bun test --coverage --coverage-reporter=lcov --reporter=junit --reporter=default > junit.xml",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@adieuu/shared": "workspace:*",
    "@simplewebauthn/server": "^13.2.2",
    "ioredis": "^5.4.2",
    "mongodb": "^6.14.2",
    "otpauth": "^9.5.0",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0"
  },
  "devDependencies": {
    "@adieuu/tsconfig": "workspace:*",
    "@types/bun": "^1.3.9",
    "typescript": "^5.7.3"
  }
}
