{
  "name": "@chadder/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@chadder/shared": "workspace:*"
  },
  "devDependencies": {
    "@chadder/tsconfig": "workspace:*",
    "@types/bun": "^1.3.9",
    "typescript": "^5.7.3"
  }
}
