{
  "name": "adieuu",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "build:packages": "pnpm run package:lambdas:force",
    "dev": "turbo run dev --filter=@adieuu/api --filter=@adieuu/web --filter=@adieuu/chat",
    "dev:web": "turbo run dev --filter=@adieuu/web",
    "dev:api": "turbo run dev --filter=@adieuu/api",
    "dev:desktop": "turbo run dev --filter=@adieuu/desktop",
    "dev:chat": "turbo run dev --filter=@adieuu/chat",
    "dev:proxy": "caddy run",
    "package:media-db-writer": "cd infra/aws/lambda/media-db-writer && pnpm run package",
    "package:media-processor": "cd infra/aws/lambda/media-processor && pnpm run package",
    "package:media-video-moderation-complete": "cd infra/aws/lambda/media-video-moderation-complete && pnpm run package",
    "package:lambdas": "bash package-lambdas.sh",
    "package:lambdas:force": "bash package-lambdas.sh --force",
    "services:up": "docker compose up -d",
    "services:down": "docker compose down",
    "services:logs": "docker compose logs -f",
    "services:status": "docker ps --format 'table {{.Names}}\t{{.Ports}}'",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:all": "pnpm run test && pnpm run test:fs && pnpm run test:security",
    "test:force": "turbo run test --force",
    "test:video-processing": "node scripts/test-video-processing.mjs",
    "test:fs": "pnpm --filter @adieuu/ui test -- ./src/hooks/usePreKeys.scheduler.test.ts ./src/services/preKeyStorage.test.ts ./src/services/preKeyService.test.ts && pnpm --filter @adieuu/api test -- ./src/repositories/pre-key.repository.test.ts ./src/routes/identity/pre-key.controller.test.ts",
    "test:security": "pnpm --filter @adieuu/api test -- ./src/repositories/session.repository.test.ts ./src/repositories/block.repository.test.ts ./src/repositories/mfa.repository.test.ts ./src/services/session.service.test.ts ./src/services/rate-limit.service.test.ts ./src/services/block.service.test.ts ./src/services/mfa.service.test.ts && pnpm --filter @adieuu/api test -- ./src/routes/blocks/controller.test.ts ./src/routes/mfa/controller.test.ts",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "if git diff --cached --name-only | grep -qE '(pnpm-lock\\.yaml|package\\.json|\\.npmrc)$'; then node scripts/audit-supply-chain.mjs; fi"
  },
  "devDependencies": {
    "playwright": "1.59.1",
    "simple-git-hooks": "2.13.1",
    "turbo": "2.9.16",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=25.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "immutable": ">=5.1.5",
      "rollup": ">=4.59.0",
      "tar": ">=7.5.9",
      "minimatch": "10.2.4",
      "@develar/schema-utils": "workspace:*",
      "ajv": "8.18.0",
      "ajv-keywords": "5.1.0",
      "ajv-formats": "2.1.1",
      "dmg-license>ajv": ">=6.14.0",
      "picomatch": ">=4.0.4",
      "brace-expansion": "5.0.6",
      "fast-uri": "3.1.2",
      "tmp": "0.2.6",
      "@xmldom/xmldom": ">=0.8.13 <0.9.0",
      "lodash": ">=4.18.0",
      "postcss": ">=8.5.10 <9.0.0",
      "fast-xml-parser": ">=5.7.0 <6.0.0",
      "ip-address": ">=10.1.1 <11.0.0",
      "vite": ">=6.4.2 <7.0.0"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@emoji-mart/data": "1.2.1",
    "@emoji-mart/react": "1.1.1"
  }
}
