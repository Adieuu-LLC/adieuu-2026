{
  "name": "chadder",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@chadder/web",
    "dev:api": "turbo run dev --filter=@chadder/api",
    "dev:desktop": "turbo run dev --filter=@chadder/desktop",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=25.0.0",
    "pnpm": ">=9.0.0"
  }
}
