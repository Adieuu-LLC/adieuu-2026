{
  "name": "@adieuu/ui",
  "version": "0.1.80",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.scss": "./src/styles.scss",
    "./i18n": {
      "types": "./dist/i18n/index.d.ts",
      "import": "./dist/i18n/index.js"
    },
    "./icons/registry": {
      "types": "./dist/icons/registry.d.ts",
      "import": "./dist/icons/registry.js"
    },
    "./csp": {
      "types": "./dist/csp.d.ts",
      "import": "./dist/csp.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "bun test --preload ./src/test.setup.ts",
    "test:coverage": "bun test --preload ./src/test.setup.ts --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@adieuu/crypto": "workspace:*",
    "@adieuu/shared": "workspace:*",
    "@ark-ui/react": "5.31.0",
    "@awesome.me/kit-888aad49e1": "1.0.2",
    "@emoji-mart/data": "1.2.1",
    "@emoji-mart/react": "1.1.1",
    "@fortawesome/fontawesome-svg-core": "7.2.0",
    "@fortawesome/react-fontawesome": "3.3.0",
    "@simplewebauthn/browser": "13.2.2",
    "i18next": "24.2.3",
    "qrcode.react": "4.2.0",
    "react-i18next": "15.7.4",
    "react-virtuoso": "4.18.4",
    "recharts": "2.15.4"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@adieuu/tsconfig": "workspace:*",
    "@types/bun": "1.3.9",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "fake-indexeddb": "6.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "7.13.0",
    "typescript": "5.9.3"
  }
}
