{
  "name": "@adieuu/ui",
  "version": "0.4.4",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.scss": "./src/styles.scss",
    "./i18n": {
      "types": "./dist/i18n/index.d.ts",
      "import": "./dist/i18n/index.js"
    },
    "./icons/registry": {
      "types": "./dist/icons/registry.d.ts",
      "import": "./dist/icons/registry.js"
    },
    "./csp": {
      "types": "./dist/csp.d.ts",
      "import": "./dist/csp.js"
    },
    "./services/crashReporter": {
      "types": "./dist/services/crashReporter.d.ts",
      "import": "./dist/services/crashReporter.js"
    }
  },
  "scripts": {
    "postinstall": "node scripts/copy-ffmpeg-core.mjs",
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "biome lint src/",
    "test": "bun test --preload ./src/test.setup.ts",
    "test:coverage": "bun test --preload ./src/test.setup.ts --coverage",
    "test:ci": "bun test --preload ./src/test.setup.ts --coverage --coverage-reporter=lcov --coverage-dir=coverage",
    "test:a11y": "node ./node_modules/@playwright/test/cli.js test --config playwright.config.ts --project=public",
    "test:a11y:all": "node ./node_modules/@playwright/test/cli.js test --config playwright.config.ts",
    "test:compliance": "node ./node_modules/@playwright/test/cli.js test --config playwright.config.ts --project=compliance",
    "test:crypto": "node ./node_modules/@playwright/test/cli.js test --config playwright.config.ts --project=crypto",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@adieuu-llc/fa-sharp-duotone-solid-svg-icons": "7.2.0",
    "@adieuu/crypto": "workspace:*",
    "@adieuu/shared": "workspace:*",
    "@ark-ui/react": "5.31.0",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@emoji-mart/data": "1.2.1",
    "@emoji-mart/react": "1.1.1",
    "@ffmpeg/core": "0.12.6",
    "@ffmpeg/ffmpeg": "0.12.15",
    "@ffmpeg/util": "0.12.2",
    "@fortawesome/fontawesome-svg-core": "npm:@adieuu-llc/fa-fontawesome-svg-core@7.2.0",
    "@fortawesome/react-fontawesome": "3.3.0",
    "@friendlycaptcha/sdk": "1.0.1",
    "@livekit/components-react": "2.9.21",
    "@livekit/components-styles": "1.2.0",
    "@simplewebauthn/browser": "13.2.2",
    "i18next": "24.2.3",
    "livekit-client": "2.19.1",
    "qrcode.react": "4.2.0",
    "react-i18next": "15.7.4",
    "recharts": "2.15.4",
    "three": "0.183.2"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@adieuu/tsconfig": "workspace:*",
    "@axe-core/playwright": "4.12.1",
    "@biomejs/biome": "2.5.1",
    "@playwright/test": "1.61.1",
    "@types/bun": "1.3.9",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@types/three": "0.183.1",
    "axe-core": "4.12.1",
    "fake-indexeddb": "6.2.5",
    "happy-dom": "20.9.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "7.15.1",
    "typescript": "5.9.3"
  }
}
