{
  "name": "@adieuu/crypto",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./keys": {
      "types": "./dist/keys/index.d.ts",
      "import": "./dist/keys/index.js"
    },
    "./encrypt": {
      "types": "./dist/encrypt/index.d.ts",
      "import": "./dist/encrypt/index.js"
    },
    "./sign": {
      "types": "./dist/sign/index.d.ts",
      "import": "./dist/sign/index.js"
    },
    "./kdf": {
      "types": "./dist/kdf/index.d.ts",
      "import": "./dist/kdf/index.js"
    },
    "./ciphers": {
      "types": "./dist/ciphers/index.d.ts",
      "import": "./dist/ciphers/index.js"
    },
    "./csp": {
      "types": "./dist/csp.d.ts",
      "import": "./dist/csp.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:ci": "bun test --coverage --coverage-reporter=lcov --reporter=junit --reporter-outfile=junit.xml",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@noble/ciphers": "1.3.0",
    "@noble/curves": "1.9.7",
    "@noble/hashes": "1.8.0",
    "@noble/post-quantum": "0.2.1",
    "hash-wasm": "4.12.0"
  },
  "devDependencies": {
    "@adieuu/tsconfig": "workspace:*",
    "@types/bun": "1.3.9",
    "typescript": "5.9.3"
  }
}
