# Jitsi Meet local development environment
#
# Copy to .jitsi.env before running:
#   cp .jitsi.env.example .jitsi.env
#   docker compose --profile jitsi up -d
#
# These defaults match the API config in apps/api/src/config/index.ts so
# tokens minted by the API are accepted by Prosody without extra setup.

# ---------------------------------------------------------------------------
# XMPP domains
#
# The XMPP_DOMAIN below must match JITSI_XMPP_DOMAIN in apps/api/.env
# (or default to the hostname of JITSI_BASE_URL if JITSI_XMPP_DOMAIN is
# not set). When connecting via localhost, set JITSI_XMPP_DOMAIN=meet.jitsi
# in the API .env so the JWT and XMPP handshake use the correct domain.
# ---------------------------------------------------------------------------
XMPP_DOMAIN=meet.jitsi
XMPP_AUTH_DOMAIN=auth.meet.jitsi
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
XMPP_MUC_DOMAIN=muc.meet.jitsi
XMPP_GUEST_DOMAIN=guest.meet.jitsi
XMPP_RECORDER_DOMAIN=recorder.meet.jitsi

# ---------------------------------------------------------------------------
# Authentication -- JWT (must match API JITSI_JWT_* config)
# ---------------------------------------------------------------------------
ENABLE_AUTH=1
AUTH_TYPE=jwt
JWT_APP_ID=adieuu
JWT_APP_SECRET=dev-jitsi-jwt-secret
JWT_ACCEPTED_ISSUERS=adieuu
JWT_ACCEPTED_AUDIENCES=jitsi
JWT_ALLOW_EMPTY=0

# ---------------------------------------------------------------------------
# Jicofo
# ---------------------------------------------------------------------------
JICOFO_AUTH_USER=focus
JICOFO_AUTH_PASSWORD=dev-jicofo-password

# ---------------------------------------------------------------------------
# JVB (Jitsi Videobridge)
# ---------------------------------------------------------------------------
JVB_AUTH_USER=jvb
JVB_AUTH_PASSWORD=dev-jvb-password
JVB_PORT=10000
JVB_ADVERTISE_IPS=127.0.0.1

# ---------------------------------------------------------------------------
# Web / general
# ---------------------------------------------------------------------------
PUBLIC_URL=https://localhost
DISABLE_HTTPS=1
ENABLE_XMPP_WEBSOCKET=1
ENABLE_COLIBRI_WEBSOCKET=1

# Time zone for container logs
TZ=UTC
