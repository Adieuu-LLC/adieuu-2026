# Adieuu Environment Variables
#
# This file documents all environment variables used across the project.
# Copy this to .env and fill in your values for local development.
# For production, use your CI/CD secrets management (e.g., GitHub Secrets).
#
# Note: Variables prefixed with VITE_ are embedded at build time for web/desktop apps.

# =============================================================================
# API Server (apps/api)
# =============================================================================

# Environment mode
NODE_ENV=development

# Server configuration
PORT=4000
HOST=0.0.0.0

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=adieuu

# Redis
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=adieuu:

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://localhost

# Cookie domain for cross-subdomain sharing (production only)
# Set to parent domain with leading dot, e.g., .adieuu.com
# Leave empty for localhost development
COOKIE_DOMAIN=

# Security secrets (MUST change in production)
CSRF_SECRET=dev-csrf-secret-change-in-prod
SESSION_SECRET=dev-session-secret-change-in-prod
OTP_SECRET=dev-otp-secret-change-in-prod

# Account-identity separation secrets
# ACCOUNT_HASH_SECRET: HMAC key for deriving non-reversible account hashes.
#   Non-rotatable (changing invalidates all identity logins).
#   In production, injected by ECS from AWS Secrets Manager.
ACCOUNT_HASH_SECRET=dev-account-hash-secret-change-in-prod
# TOKEN_SIGNING_KEY: HMAC key for short-lived JWTs bridging account→identity.
#   Rotatable (clients get fresh token on next session refresh).
TOKEN_SIGNING_KEY=dev-token-signing-key-change-in-prod

# Email (AWS SES)
EMAIL_PROVIDER=console
EMAIL_FROM_ADDRESS=noreply@adieuu.com
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SMS (TextMagic)
SMS_PROVIDER=console
TEXTMAGIC_USERNAME=
TEXTMAGIC_API_KEY=
SMS_FROM_NAME=Adieuu

# WebAuthn
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGINS=http://localhost:5173,https://localhost

# Web app URL (for magic links, redirects)
WEB_APP_URL=http://localhost:3000

# Feature flags
REQUIRE_DATABASE=false
INITIALIZE_COLLECTIONS=false

# Rate limiting
RATE_LIMIT_ENABLED=true

# IP Geolocation (IPLocate.io)
# Server-side only. Required when GEO_LOOKUP_ENABLED=true in production.
IPLOCATE_API_KEY=
# IPLOCATE_BASE_URL=https://www.iplocate.io/api/lookup  # default
# IPLOCATE_TIMEOUT_MS=2500                              # default
# GEO_LOOKUP_ENABLED=false                              # also toggleable via platform settings
# GEO_CACHE_TTL_SECONDS=86400                           # 24h Redis cache for IP results
# GEO_RECHECK_INTERVAL_DAYS=30                          # how often to re-check per user
# TRUST_PROXY_HEADERS=false                             # MUST be true in production behind a trusted proxy

# Klipy GIF/sticker API (https://partner.klipy.com/)
# Required in production; leave empty to disable GIF proxy in dev
KLIPY_API_KEY=

# =============================================================================
# Chat Server (apps/chat)
# =============================================================================

CHAT_PORT=9001
CHAT_HOST=0.0.0.0
WS_IDLE_TIMEOUT=120
WS_MAX_PAYLOAD_LENGTH=1048576
WS_COMPRESSION=true
PRESENCE_HEARTBEAT_TTL=30
PRESENCE_HEARTBEAT_INTERVAL=15

# =============================================================================
# Web App Build (apps/web) - VITE_ prefix required
# =============================================================================

# API base URL (empty for same-origin in dev, set for production)
# VITE_API_BASE_URL=https://api.adieuu.com

# Chat WebSocket URL (AWS: same host as API; ALB routes /ws/* to chat)
# VITE_CHAT_WS_URL=wss://api.adieuu.com/ws/chat

# S3 origins for CSP (presigned PUT/GET for media uploads).
# Optional; defaults to production buckets when unset.
# VITE_MEDIA_S3_ORIGIN=https://your-media-bucket.s3.us-east-1.amazonaws.com
# VITE_E2E_MEDIA_S3_ORIGIN=https://your-e2e-media-bucket.s3.us-east-1.amazonaws.com

# =============================================================================
# Desktop App Build (apps/desktop) - VITE_ prefix required
# =============================================================================

# API URL
# VITE_API_URL=https://api.adieuu.com

# Chat WebSocket URL (ALB routes /ws/* on the API domain to the chat service)
# VITE_CHAT_WS_URL=wss://api.adieuu.com/ws/chat

# =============================================================================
# CI/CD GitHub Secrets
# =============================================================================
#
# The following secrets should be configured in GitHub repository settings
# (Settings > Secrets and variables > Actions > Repository secrets):
#
# Build-time secrets (for web/desktop builds):
#   VITE_API_BASE_URL      - e.g., https://api.adieuu.com
#   VITE_API_URL           - e.g., https://api.adieuu.com (desktop uses this name)
#   VITE_CHAT_WS_URL       - e.g., wss://api.adieuu.com/ws/chat
#
# GitHub Actions (production web deploy): set repository variables
# DEPLOY_WEB_VITE_API_BASE_URL_ADIEUU and DEPLOY_WEB_VITE_CHAT_WS_URL_ADIEUU
# (see docs/deployment/github-actions-aws.md).
#
# Runtime secrets (for API server - configure in your deployment platform):
#   COOKIE_DOMAIN          - e.g., .adieuu.com
#   CSRF_SECRET            - Generate with: openssl rand -base64 32
#   SESSION_SECRET         - Generate with: openssl rand -base64 32
#   OTP_SECRET             - Generate with: openssl rand -base64 32
#   AWS_ACCESS_KEY_ID      - AWS IAM credentials for SES
#   AWS_SECRET_ACCESS_KEY  - AWS IAM credentials for SES
#   TEXTMAGIC_USERNAME     - TextMagic API username
#   TEXTMAGIC_API_KEY      - TextMagic API key
#   MONGODB_URI            - MongoDB connection string
#   REDIS_URL              - Redis connection string
#
# Third-party service secrets:
#   CODECOV_TOKEN          - Codecov upload token
#   MANIFEST_API_KEY       - Manifest SBOM upload key
